# Sao chép file này thành .env.prod rồi điền giá trị thật.
#   cp .env.prod.example .env.prod
# .env.prod ĐÃ bị .gitignore — KHÔNG commit secrets.

# ===== Database =====
POSTGRES_DB=meup
POSTGRES_USER=meup
POSTGRES_PASSWORD=CHANGE_ME_mat_khau_db_manh

# ===== JWT (BẮT BUỘC đổi — chuỗi ngẫu nhiên >= 32 ký tự) =====
# Tạo nhanh:  openssl rand -base64 48
JWT_KEY=CHANGE_ME_chuoi_ngau_nhien_that_dai_it_nhat_32_ky_tu
JWT_ISSUER=MeUp.Api
JWT_AUDIENCE=MeUp.Client

# ===== Frontend origin (Cloudflare Pages) — dùng cho CORS + link email =====
FRONTEND_ORIGIN=https://meup.pages.dev

# ===== Tài khoản admin khởi tạo lần đầu =====
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_mat_khau_admin_manh

# ===== Cloudflare Tunnel token (lấy ở Zero Trust > Networks > Tunnels) =====
CLOUDFLARE_TUNNEL_TOKEN=

# ===== AI Claude (tùy chọn — để trống là tắt) =====
